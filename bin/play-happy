#!/bin/bash
#***************************************************************************
#*** play-happy - celebrate wins with random meme videos + text overlay
#***************************************************************************

VERSION="0.1.0"

#***** color scheme *****
GREEN='\033[1;32m'
RED='\033[1;31m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
BLUE='\033[1;34m'
DIM='\033[2m'
BOLD='\033[1m'
RESET='\033[0m'

#***** helper functions *****
print_header() {
    echo -e "${CYAN}${BOLD}⚡ play-happy${RESET}"
}

print_success() {
    echo -e "${GREEN}✓${RESET} $1"
}

print_error() {
    echo -e "${RED}✗${RESET} $1"
}

print_status() {
    echo -e "  ${GREEN}→${RESET} $1"
}

print_dim() {
    echo -e "  ${DIM}$1${RESET}"
}

#***** media directory *****
MEDIA_DIR="$(brew --prefix 2>/dev/null)/share/play-happy/media"
if [[ ! -d "$MEDIA_DIR" ]]; then
    # Fallback: look relative to the script
    SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
    MEDIA_DIR="$SCRIPT_DIR/media"
fi

#***** show help *****
show_help() {
    echo
    print_header
    echo -e "  ${DIM}celebrate wins with random meme videos${RESET}"
    echo
    echo -e "${BLUE}USAGE${RESET}"
    echo -e "    play-happy \"your celebration message\""
    echo
    echo -e "${BLUE}OPTIONS${RESET}"
    echo -e "    -h, --help         Show this help"
    echo -e "    -v, --version      Show version"
    echo -e "    -l, --list         List available videos"
    echo -e "    -p, --pick NAME    Play a specific video"
    echo -e "    --no-check         Skip clamshell check"
    echo
    echo -e "${BLUE}EXAMPLES${RESET}"
    echo -e "    ${DIM}play-happy \"shipped it\"${RESET}"
    echo -e "    ${DIM}play-happy -l${RESET}"
    echo -e "    ${DIM}play-happy -p gladiator \"we are entertained\"${RESET}"
    echo -e "    ${DIM}play-happy --no-check \"testing\"${RESET}"
    echo
    echo -e "${BLUE}REQUIREMENTS${RESET}"
    echo -e "    macOS, mpv (brew install mpv)"
    echo
}

#***** argument parsing *****
SKIP_CHECKS=false
PICK_VIDEO=""
LIST_MODE=false
TEXT_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            show_help
            exit 0
            ;;
        -v|--version)
            echo "play-happy $VERSION"
            exit 0
            ;;
        -l|--list)
            LIST_MODE=true
            shift
            ;;
        -p|--pick)
            PICK_VIDEO="$2"
            shift 2
            ;;
        --no-check)
            SKIP_CHECKS=true
            shift
            ;;
        *)
            TEXT_ARGS+=("$1")
            shift
            ;;
    esac
done

#***** list mode *****
if $LIST_MODE; then
    if [[ ! -d "$MEDIA_DIR" ]]; then
        print_error "media directory not found: $MEDIA_DIR"
        exit 1
    fi
    print_header
    echo
    for f in "$MEDIA_DIR"/*.mp4; do
        [[ -f "$f" ]] || continue
        echo -e "  ${GREEN}→${RESET} $(basename "$f" .mp4)"
    done
    echo
    exit 0
fi

#***** require text *****
TEXT="${TEXT_ARGS[*]}"
if [[ -z "$TEXT" ]]; then
    print_error "text is required — play-happy \"your message here\""
    exit 1
fi

#***** check mpv *****
if ! command -v mpv &>/dev/null; then
    print_error "mpv is required: brew install mpv"
    exit 1
fi

#***** environment checks *****
if ! $SKIP_CHECKS; then
    # Skip if lid is closed (clamshell mode)
    clamshell="$(ioreg -r -k AppleClamshellState -d 4 | grep AppleClamshellState | head -1)"
    if [[ "$clamshell" == *"Yes"* ]]; then
        print_dim "lid is closed, skipping — \"$TEXT\""
        exit 0
    fi
fi

#***** pick video *****
if [[ -n "$PICK_VIDEO" ]]; then
    vid="$MEDIA_DIR/${PICK_VIDEO}.mp4"
    if [[ ! -f "$vid" ]]; then
        # Try partial match
        vid="$(find "$MEDIA_DIR" -maxdepth 1 -type f -name "*${PICK_VIDEO}*.mp4" | head -1)"
    fi
    if [[ -z "$vid" || ! -f "$vid" ]]; then
        print_error "video not found: $PICK_VIDEO"
        exit 1
    fi
else
    vid="$(find "$MEDIA_DIR" -maxdepth 1 -type f -name '*.mp4' | sort -R | head -1)"
    if [[ -z "$vid" ]]; then
        print_error "no videos found in $MEDIA_DIR"
        exit 1
    fi
fi

#***** ensure volume *****
sys_vol=$(osascript -e 'output volume of (get volume settings)' 2>/dev/null)
if [[ -n "$sys_vol" ]] && (( sys_vol < 25 )); then
    print_dim "volume too low (${sys_vol}%), bumping to 25%"
    osascript -e 'set volume output volume 25'
fi

#***** build subtitle overlay *****
# Strip emojis — mpv subtitle renderer can't find the font
clean_text="$(echo "$TEXT" | perl -CS -pe 's/[\x{1F300}-\x{1FAFF}\x{2600}-\x{27BF}\x{FE00}-\x{FE0F}\x{200D}\x{2300}-\x{23FF}]//g; s/\s+/ /g; s/^\s+|\s+$//g')"
tmp_sub="$(mktemp /tmp/play-happy.XXXXXX).ass"
cat > "$tmp_sub" <<ASSEOF
[Script Info]
ScriptType: v4.00+
PlayResX: 1920
PlayResY: 1080

[V4+ Styles]
Format: Name,Fontname,Fontsize,PrimaryColour,SecondaryColour,OutlineColour,BackColour,Bold,Italic,Underline,StrikeOut,ScaleX,ScaleY,Spacing,Angle,BorderStyle,Outline,Shadow,Alignment,MarginL,MarginR,MarginV,Encoding
Style: Big,Helvetica Neue,80,&H00FFFFFF,&H000000FF,&H00000000,&H80000000,-1,0,0,0,100,100,0,0,1,3,4,5,40,40,60,1

[Events]
Format: Layer,Start,End,Style,Name,MarginL,MarginR,MarginV,Effect,Text
Dialogue: 0,0:00:00.00,9:99:99.99,Big,,0,0,0,,${clean_text}
ASSEOF

#***** play *****
if [[ -t 1 ]]; then
    print_status "playing $(basename "$vid" .mp4) — \"$TEXT\""
fi
mpv --fs --volume=50 --really-quiet --sub-file="$tmp_sub" "$vid" 2>/dev/null
rm -f "$tmp_sub"

if [[ -t 1 ]]; then
    print_success "played"
fi
